@model IEnumerable<BikeStores.Models.Store>

@{
    ViewData["Title"] = "Stores";
}

<div class="page-header">
    <h1>Stores</h1>

    <form method="get" class="mb-2">
        <div class="input-group">
            <input type="text" name="search" class="form-control" placeholder="Search by city or state..." value="@ViewBag.Search" />
            <button type="submit" class="btn btn-primary">Search</button>
            <a asp-action="Index" class="btn btn-secondary">Clear</a>
        </div>
    </form>
</div>

@if (!Model.Any())
{
    <p class="text-muted">No stores found.</p>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Store Name</th>
                <th>Phone</th>
                <th>Email</th>
                <th>City</th>
                <th>State</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.StoreName</td>
                    <td>@item.Phone</td>
                    <td>@item.Email</td>
                    <td>@item.City</td>
                    <td>@item.State</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.StoreId" class="btn btn-sm btn-info">Details</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
