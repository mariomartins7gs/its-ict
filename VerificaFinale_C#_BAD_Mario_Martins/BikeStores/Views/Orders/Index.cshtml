@model IEnumerable<BikeStores.Models.Order>

@{
    ViewData["Title"] = "Orders";
}

<div class="page-header">
    <h1>Orders</h1>

    <form method="get" class="mb-2">
        <div class="input-group">
            <input type="text" name="search" class="form-control" placeholder="Search by customer name or status (Pending, Processing, Rejected, Completed)..." value="@ViewBag.Search" />
            <button type="submit" class="btn btn-primary">Search</button>
            <a asp-action="Index" class="btn btn-secondary">Clear</a>
        </div>
    </form>
</div>

@if (!Model.Any())
{
    <p class="text-muted">No orders found.</p>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Order ID</th>
                <th>Customer</th>
                <th>Status</th>
                <th>Order Date</th>
                <th>Store</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.OrderId</td>
                    <td>@($"{item.Customer?.FirstName} {item.Customer?.LastName}")</td>
                    <td>
                        @switch (item.OrderStatus)
                        {
                            case 1: <span class="badge bg-warning">Pending</span>; break;
                            case 2: <span class="badge bg-info">Processing</span>; break;
                            case 3: <span class="badge bg-danger">Rejected</span>; break;
                            case 4: <span class="badge bg-success">Completed</span>; break;
                            default: <span class="badge bg-secondary">Unknown</span>; break;
                        }
                    </td>
                    <td>@item.OrderDate.ToString("yyyy-MM-dd")</td>
                    <td>@item.Store?.StoreName</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.OrderId" class="btn btn-sm btn-info">Details</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
