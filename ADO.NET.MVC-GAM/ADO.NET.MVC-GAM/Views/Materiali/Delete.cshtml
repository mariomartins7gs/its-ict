@model Materiale

@{
    ViewData["Title"] = "Elimina materiale";
}

<h1>Elimina materiale</h1>

<div class="alert alert-danger">
    <h4>Sei sicuro di voler eliminare questo materiale?</h4>
</div>

<div>
    <dl class="row">
        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Id)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Id)</dd>

        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Denominazione)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Denominazione)</dd>
    </dl>

    <form asp-action="Delete">
        <input type="submit" value="Elimina" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary">Annulla</a>
    </form>
</div>
