@model Materiale

@{
    ViewData["Title"] = "Dettagli materiale";
}

<h1>Dettagli materiale</h1>

<div>
    <dl class="row">
        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Id)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Id)</dd>

        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Denominazione)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Denominazione)</dd>
    </dl>

    @if (Model.OperaMateriali.Any())
    {
        <h4>Opere associate (@Model.OperaMateriali.Count)</h4>
        <ul>
            @foreach (var om in Model.OperaMateriali)
            {
                <li>@om.IdOperaNavigation.Titolo_soggetto (Inv. @om.IdOperaNavigation.Inventario)</li>
            }
        </ul>
    }
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Modifica</a>
    <a asp-action="Index" class="btn btn-secondary">Torna all'elenco</a>
</div>
