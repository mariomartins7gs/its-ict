@model IEnumerable<Opera>

@{
    ViewData["Title"] = "Opere";
}

<h1>Opere</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Nuova opera</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.Inventario)</th>
            <th>@Html.DisplayNameFor(model => model.Titolo_soggetto)</th>
            <th>@Html.DisplayNameFor(model => model.IdAutoreNavigation)</th>
            <th>@Html.DisplayNameFor(model => model.Datazione)</th>
            <th>Azioni</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.Inventario)</td>
                <td>@Html.DisplayFor(modelItem => item.Titolo_soggetto)</td>
                <td>@Html.DisplayFor(modelItem => item.IdAutoreNavigation!.Nominativo)</td>
                <td>@Html.DisplayFor(modelItem => item.Datazione)</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Modifica</a>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Dettagli</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Elimina</a>
                </td>
            </tr>
        }
    </tbody>
</table>
